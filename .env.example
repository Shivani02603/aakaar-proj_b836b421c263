# Database connection string for PostgreSQL
DATABASE_URL=postgresql://<username>:<password>@<host>:<port>/<database>

# Secret key for JWT authentication
JWT_SECRET=<random secret>

# Backend server port
PORT=8000

# Frontend API URL for development
VITE_API_URL=http://localhost:8000

# PostgreSQL environment variables
POSTGRES_USER=appuser  # Username for PostgreSQL
POSTGRES_PASSWORD=securepassword  # Password for PostgreSQL
POSTGRES_DB=appdb  # Database name for PostgreSQL

# OpenAI API key for embedding generation
OPENAI_API_KEY=<your_openai_api_key>

# Optional: Other API keys for future use
ANTHROPIC_API_KEY=<your_anthropic_api_key>  # For Anthropic API
GOOGLE_GEMINI_API_KEY=<your_google_gemini_api_key>  # For Google Gemini API
PINECONE_API_KEY=<your_pinecone_api_key>  # For Pinecone vector storage